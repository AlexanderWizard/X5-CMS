{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "css": "sass resources/scss/admin.scss:public/css/admin.css resources/scss/landing.scss:public/css/landing.css --style=compressed --no-source-map",
